@startuml
title Group Chat — Sequence Diagram
skinparam sequenceMessageAlign center

actor Alice
participant "ChatClient\n(Alice)" as CA
participant "ChatServer" as S
participant "ClientHandler\n(Alice)" as HA
participant "ClientHandler\n(Bob)" as HB
participant "ChatClient\n(Bob)" as CB
actor Bob

== Connection & login ==
Alice -> CA : enter username "Alice"
CA -> S : TCP connect
S -> HA : spawn handler thread
CA -> HA : LOGIN|Alice
HA --> CA : WELCOME|Alice
HA -> S : onClientLoggedIn()\n(log "Welcome Alice")

== Real-time broadcast ==
Alice -> CA : type "hello" + SEND
CA -> HA : MSG|hello
HA -> S : broadcast("Alice", "hello")
S --> HA : CHAT|[time] Alice: hello
S --> HB : CHAT|[time] Alice: hello
HA --> CA : CHAT|[time] Alice: hello
HB --> CB : CHAT|[time] Alice: hello

== Active user inquiry ==
Alice -> CA : type "allUsers"
CA -> HA : USERS
HA -> S : activeUsernames()
HA --> CA : USERS|Alice, Bob

== Read-only rejection ==
note over CB : Bob joined without a username
CB -> HB : MSG|hi
HB --> CB : INFO|READ-ONLY mode, cannot send

== Disconnect ==
Alice -> CA : type "end"
CA -> HA : BYE
HA -> S : removeClient()\n(log "Alice disconnected")
HA --> CA : socket closed
@enduml

@startuml
title Group Chat — Use Case Diagram
left to right direction
skinparam packageStyle rectangle

actor "Registered User" as User
actor "Guest\n(read-only)" as Guest

rectangle "Group Chat Application" {
  usecase UC1 as "Log in with username"
  usecase UC2 as "Send message"
  usecase UC3 as "Receive broadcast messages"
  usecase UC4 as "List active users\n(allUsers)"
  usecase UC5 as "Disconnect\n(end / bye)"
  usecase UC6 as "Connect in read-only mode"
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5

Guest --> UC6
Guest --> UC3

UC2 ..> UC1 : <<include>>
UC4 ..> UC1 : <<include>>
@enduml
